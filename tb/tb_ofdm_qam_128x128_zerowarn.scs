// Coherent-demodulation testbench for 128x128 OFDM/QAM-RRAM MVM
// Every BL/carrier path uses BPF, phase-window verification demodulator, and RC integration.
simulator lang=spectre
include "../netlist/clean_128x128_crossbar.scs"

parameters rclosed_mix=1 ropen_mix=1G

